# Required: use Supabase as the dataset backend.
DATASET_BACKEND=supabase

# Required: Supabase project URL.
SUPABASE_URL=https://YOUR_PROJECT.supabase.co

# Required: Supabase service role key.
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY

# Required for translation/upload features that call Anthropic.
ANTHROPIC_API_KEY=YOUR_ANTHROPIC_API_KEY

# Optional: long chapters can take longer than 30-40s with Opus.
ANTHROPIC_TIMEOUT_SECONDS=180
ANTHROPIC_TRANSLATE_MODEL=claude-opus-4-5
ANTHROPIC_TRANSLATE_MAX_TOKENS=8192
ANTHROPIC_EXPLAIN_MODEL=claude-sonnet-4-5
ANTHROPIC_EXPLAIN_MAX_TOKENS=900
ANTHROPIC_TONE_MODEL=claude-sonnet-4-5
ANTHROPIC_TONE_MAX_TOKENS=900
ANTHROPIC_VERIFY_MODEL=claude-sonnet-4-5
ANTHROPIC_VERIFY_MAX_TOKENS=3500
ANTHROPIC_VERIFY_MAX_INPUT_CHARS=50000

# Optional: frontend origins allowed to call the backend.
BACKEND_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Optional: backend local data paths.
GLOSSARY_PATH=../data/glossary.json
STYLE_GUIDE_PATH=../data/style_guide_v1.md
JOB_STORE_PATH=../data/jobs.sqlite3
DRAFT_HISTORY_STORE_PATH=../data/draft_history.sqlite3

# Optional: upload job retention tuning.
UPLOAD_JOB_TTL_SECONDS=3600
UPLOAD_JOB_MAX_ENTRIES=200
